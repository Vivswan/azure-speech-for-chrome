{
  "name": "azure-speech-for-chrome",
  "version": "1.0.3",
  "description": "A wrapper for Azure Speech Services that transforms highlighted text into high-quality natural sounding audio.",
  "main": "index.js",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "bun scripts/validate-translations.cjs && bun scripts/bun.config.js",
    "dev": "bun scripts/bun.config.js --watch",
    "lint": "bunx eslint .",
    "lint:actions": "bun run scripts/lint-actions.js",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.test.json --noEmit",
    "test": "node scripts/run-vitest.js run",
    "test:run": "node scripts/run-vitest.js run",
    "test:watch": "node scripts/run-vitest.js watch",
    "test:ui": "node scripts/run-vitest.js --ui",
    "test:coverage": "node scripts/run-vitest.js run --coverage",
    "test:coverage:ui": "node scripts/run-vitest.js --coverage --ui",
    "generate-icons": "bun scripts/generate-icons.js",
    "bump-version": "bun scripts/bump-version.js",
    "validate-translations": "bun scripts/validate-translations.cjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "author": "Vivswan Shah",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.38",
    "@types/he": "^1.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "archiver": "^7.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun": "^1.3.10",
    "crx": "^5.0.1",
    "esbuild-plugin-babel": "^0.2.3",
    "eslint": "^10.0.2",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "lint-staged": "^16.2.7",
    "@tktco/node-actionlint": "^1.6.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "~4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "yaml-loader": "^0.9.0"
  },
  "dependencies": {
    "microsoft-cognitiveservices-speech-sdk": "^1.47.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/sanitize-html": "^2.16.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.2",
    "fuse.js": "^7.1.0",
    "he": "^1.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-feather": "^2.0.10",
    "react-router-dom": "^7.13.1",
    "sanitize-html": "^2.17.0",
    "tailwind-merge": "^3.4.0",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0"
  }
}
